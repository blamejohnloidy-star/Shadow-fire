<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>Shadow Escape: Asymmetric Survival</title>
    <style>
        * { box-sizing: border-box; user-select: none; margin: 0; padding: 0; }
        body, html { width: 100%; height: 100%; overflow: hidden; background-color: #050505; font-family: sans-serif; color: #fff; }
        #game-container { position: relative; width: 100%; height: 100%; display: flex; justify-content: center; align-items: center; }
        canvas { display: block; box-shadow: 0 0 20px rgba(0,0,0,0.8); background: #111; }
        .ui-screen { position: absolute; top: 0; left: 0; width: 100%; height: 100%; z-index: 10; display: flex; flex-direction: column; justify-content: center; align-items: center; background: rgba(5, 5, 5, 0.85); backdrop-filter: blur(8px); }
        .hidden { display: none !important; }
        h1 { font-size: 2.5rem; color: #ff3333; text-transform: uppercase; letter-spacing: 4px; margin-bottom: 20px; text-shadow: 0 0 10px rgba(255,51,51,0.6); }
        .menu-panel { background: rgba(20, 20, 20, 0.9); border: 2px solid #333; padding: 25px; border-radius: 8px; width: 90%; max-width: 500px; text-align: center; }
        .btn { display: block; width: 100%; padding: 12px; margin: 10px 0; background: #222; border: 1px solid #444; color: #fff; font-size: 1.1rem; cursor: pointer; border-radius: 4px; transition: all 0.2s; text-transform: uppercase; }
        .btn:hover { background: #ff3333; border-color: #ff6666; color: #000; font-weight: bold; }
        .btn-sec { background: #333; }
        .btn-sec:hover { background: #555; color: #fff; border-color: #777; }
        .stats-grid, .shop-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 10px; margin: 15px 0; text-align: left; }
        .stat-box, .shop-item { background: #151515; padding: 10px; border: 1px solid #222; border-radius: 4px; }
        .shop-item { display: flex; flex-direction: column; justify-content: space-between; }
        .currency-display { font-size: 1.2rem; color: #ffd700; margin-bottom: 10px; font-weight: bold; }
        #hud { position: absolute; top: 0; left: 0; width: 100%; height: 100%; pointer-events: none; z-index: 5; padding: 15px; display: flex; flex-direction: column; justify-content: space-between; }
        .hud-top { display: flex; justify-content: space-between; width: 100%; }
        .hud-panel { background: rgba(10, 10, 10, 0.75); padding: 10px 15px; border-radius: 4px; border: 1px solid #222; font-family: monospace; font-size: 1.1rem; }
        .hud-bottom { display: flex; justify-content: space-between; align-items: flex-end; width: 100%; }
        .status-bars { width: 220px; }
        .bar-container { width: 100%; background: #333; height: 14px; border-radius: 7px; margin-top: 5px; overflow: hidden; border: 1px solid #444; }
        .bar-fill { height: 100%; width: 100%; transition: width 0.1s ease; }
        #hp-fill { background: #ff3333; }
        #stamina-fill { background: #33cc33; }
        #ability-fill { background: #3399ff; }
        .alert-log { position: absolute; top: 70px; left: 50%; transform: translateX(-50%); width: 80%; max-width: 400px; text-align: center; pointer-events: none; }
        .alert-msg { background: rgba(255, 0, 0, 0.2); border: 1px solid rgba(255, 0, 0, 0.5); color: #ff9999; padding: 6px 12px; margin: 4px 0; border-radius: 4px; font-size: 0.9rem; animation: fInOut 3s forwards; }
        @keyframes fInOut { 0% { opacity:0; transform:translateY(-10px); } 10%, 80% { opacity:1; transform:translateY(0); } 100% { opacity:0; transform:translateY(10px); } }
        #mobile-controls { position: absolute; bottom: 20px; left: 20px; right: 20px; display: none; justify-content: space-between; pointer-events: none; z-index: 6; }
        .joystick-zone { width: 110px; height: 110px; background: rgba(255,255,255,0.1); border-radius: 50%; position: relative; pointer-events: auto; }
        .joystick-knob { width: 45px; height: 45px; background: rgba(255,255,255,0.3); border-radius: 50%; position: absolute; left: 32px; top: 32px; }
        .action-btns { display: grid; grid-template-columns: 1fr 1fr; gap: 8px; pointer-events: auto; }
        .m-btn { width: 55px; height: 55px; background: rgba(255,255,255,0.15); border: 2px solid rgba(255,255,255,0.3); border-radius: 50%; color: white; font-weight: bold; display: flex; justify-content: center; align-items: center; font-size: 0.75rem; }
        @media (max-width: 768px) { #mobile-controls { display: flex; } h1 { font-size: 1.8rem; } }
    </style>
</head>
<body>

<div id="game-container">
    <canvas id="gameCanvas"></canvas>
    
    <div id="hud" class="hidden">
        <div class="hud-top">
            <div class="hud-panel" id="hud-match-info">MÁQUINAS: 0/4 | VIVOS: 8</div>
