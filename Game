                <div style="margin-top:5px;">HABILIDADE [E] <div class="bar-container"><div id="ability-fill" class="bar-fill"></div></div></div>
            </div>
            <div class="hud-panel" id="hud-role" style="color: #3399ff;">SOBREVIVENTE</div>
