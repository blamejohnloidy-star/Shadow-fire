    <div id="mobile-controls">
        <div class="joystick-zone" id="touch-joy"><div class="joystick-knob" id="touch-knob"></div></div>
        <div class="action-btns">
            <div class="m-btn" id="btn-run">CORRE</div>
            <div class="m-btn" id="btn-crouch">AGACHA</div>
            <div class="m-btn" id="btn-interact">INTERAG</div>
            <div class="m-btn" id="btn-skill">HABIL.</div>
        </div>
    </div>

    <div id="menu-main" class="ui-screen">
        <h1>SHADOW ESCAPE</h1>
        <div class="menu-panel">
            <div class="currency-display">MOEDAS: <span id="menu-coins">0</span> | NV: <span id="menu-level">1</span> (<span id="menu-xp">0</span> XP)</div>
            <button class="btn" id="btn-play-surv">Jogar como Sobrevivente</button>
            <button class="btn" id="btn-play-hunt" style="border-color: #ff3333;">Jogar como Caçador</button>
            <button class="btn btn-sec" id="btn-open-shop">Loja & Personagens</button>
            <button class="btn btn-sec" id="btn-open-stats">Estatísticas</button>
        </div>
    </div>

    <div id="menu-shop" class="ui-screen hidden">
        <h1>LOJA & SELEÇÃO</h1>
        <div class="menu-panel" style="max-width: 600px;">
            <div class="currency-display">SUAS MOEDAS: <span id="shop-coins">0</span></div>
            <div class="shop-grid" id="shop-items-container"></div>
            <button class="btn btn-sec" id="btn-close-shop">Voltar</button>
        </div>
    </div>

    <div id="menu-stats" class="ui-screen hidden">
        <h1>ESTATÍSTICAS</h1>
